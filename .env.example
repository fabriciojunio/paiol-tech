# ============================================================
# PAIOL TECH — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env
# ============================================================

# --- Banco de dados (PostgreSQL) ---
DATABASE_URL="postgresql://paiol:senha@localhost:5432/paiol_db"
DIRECT_URL="postgresql://paiol:senha@localhost:5432/paiol_db"

# --- Redis (OTP sessions) ---
REDIS_URL="redis://localhost:6379"

# --- JWT ---
JWT_SECRET="troque-por-um-segredo-aleatorio-de-32-caracteres-minimo"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# --- Aplicação ---
NODE_ENV="development"
PORT=3001
APP_URL="http://localhost:3000"

# --- Admin ---
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="paiol@admin2025"

# --- WhatsApp / Z-API (produção) ---
# Deixe em branco para usar o mock em desenvolvimento
ZAPI_INSTANCE_ID=""
ZAPI_TOKEN=""

# --- Open Finance / TecnoSpeed (produção) ---
# Deixe em branco para usar o mock em desenvolvimento
TECNOSPEED_API_KEY=""
TECNOSPEED_BASE_URL="https://api.tecnospeed.com.br"

# --- Pagamentos / Pagar.me (produção) ---
# Deixe em branco para usar o mock em desenvolvimento
PAGARME_SECRET_KEY=""
PAGARME_BASE_URL="https://api.pagar.me/core/v5"
PAGARME_WEBHOOK_SECRET=""

# ============================================================
# FRONTEND (apps/web — prefixo NEXT_PUBLIC_)
# ============================================================
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# ============================================================
# ADMIN PANEL (apps/admin — prefixo NEXT_PUBLIC_)
# ============================================================
# NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# ============================================================
# E2E / CI
