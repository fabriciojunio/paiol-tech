# ==========================================
# Paiol Tech API — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env
# ==========================================

# --- Banco de Dados ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# --- Autenticação JWT ---
JWT_SECRET=mude_para_um_segredo_aleatório_de_mínimo_256_bits
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=outro_segredo_diferente_256_bits
REFRESH_TOKEN_EXPIRES_IN=30d

# --- WhatsApp (Z-API) ---
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- Open Finance (TecnoSpeed) ---
TECNO_SPEED_CLIENT_ID=
TECNO_SPEED_CLIENT_SECRET=
TECNO_SPEED_SANDBOX=true

# --- Cache (Upstash Redis) ---
REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# --- Filas (CloudAMQP RabbitMQ) ---
RABBITMQ_URL=amqps://USER:PASSWORD@HOST/VHOST

# --- Ambiente ---
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000

# --- Monitoramento ---
SENTRY_DSN=

# --- Pagamentos (Pagar.me) ---
PAGARME_API_KEY=
PAGARME_ENCRYPTION_KEY=
